# ── Telegram Bot ───────────────────────────────────────────────────────────────
BOT_TOKEN=your-telegram-bot-token

# ── База данных ────────────────────────────────────────────────────────────────
# SQLite (для разработки)
DB_DSN=sqlite:///data/implant_stock.db
ASYNC_DB_DSN=sqlite+aiosqlite:///data/implant_stock.db
# PostgreSQL (для продакшена — раскомментируйте)
# DB_DSN=postgresql+psycopg://user:password@localhost/implant_stock
# ASYNC_DB_DSN=postgresql+asyncpg://user:password@localhost/implant_stock

# ── Admin Panel (Flask) ────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password
SECRET_KEY=your-flask-secret-key

# ── Яндекс.Диск ───────────────────────────────────────────────────────────────
YD_TOKEN=your-yadisk-oauth-token
YD_PATH=disk:/exports/implant_stock.csv
YD_ROOT_PATH=/exports_implants
YD_MAIN_FOLDER=https://disk.yandex.ru/d/...
YD_REMOTE_FOLDER=https://disk.yandex.ru/d/...
YD_MAIN_PREFIX=exports_implants
YD_REMOTE_PREFIX=exports_import_remote
CRON_MAIN_MINUTES=5
CRON_REMOTE_MINUTES=30
ZIP_PASSWORD=your-zip-password
# Расходники (необязательно — если не задать, модуль supplies работает только через ручную загрузку)
YD_SUPPLIES_FOLDER=https://disk.yandex.ru/d/...
CRON_SUPPLIES_MINUTES=60
TG_INTERACTIONS_RETAIN_DAYS=180  # история Telegram-бота, дней
PWA_ACTIVITY_RETAIN_DAYS=90      # статистика PWA, дней
CARTS_RETAIN_DAYS=365            # оформленные заказы, дней
MAX_UPLOAD_MB=50                 # лимит размера загружаемого файла

# ── Email (для заказов) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USER=your-email@yandex.ru
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=your-email@yandex.ru
ORDER_EMAIL_TO=manager1@example.com,manager2@example.com

# ── FastAPI / PWA ──────────────────────────────────────────────────────────────
# Сгенерируйте: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_generate_32_char_random_hex_string_here
JWT_ALGORITHM=HS256
# Разрешённые CORS-origins (через запятую)
CORS_ORIGINS=http://localhost:5173,https://your-domain.ru
